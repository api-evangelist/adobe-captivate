{
  "@context": {
    "@version": 1.1,
    "alm": "https://learningmanager.adobe.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "LearnerReference": "alm:LearnerReference",
    "LearningObjectReference": "alm:LearningObjectReference",
    "WebhookEventBase": "alm:WebhookEventBase",
    "userId": {
      "@id": "alm:userId",
      "@type": "xsd:string"
    },
    "name": "schema:name",
    "email": "schema:email",
    "loId": {
      "@id": "alm:loId",
      "@type": "xsd:string"
    },
    "loType": {
      "@id": "alm:loType",
      "@type": "xsd:string"
    },
    "instanceId": {
      "@id": "alm:instanceId",
      "@type": "xsd:string"
    },
    "eventType": {
      "@id": "alm:eventType",
      "@type": "xsd:string"
    },
    "eventId": {
      "@id": "alm:eventId",
      "@type": "xsd:string"
    },
    "accountId": {
      "@id": "alm:accountId",
      "@type": "xsd:string"
    },
    "timestamp": {
      "@id": "alm:timestamp",
      "@type": "xsd:dateTime"
    },
    "source": {
      "@id": "alm:source",
      "@type": "xsd:string"
    }
  }
}