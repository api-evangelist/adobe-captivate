{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/adobe-captivate/refs/heads/main/json-structure/learning-manager-webhooks-certification-completed-payload-structure.json",
  "name": "CertificationCompletedPayload",
  "description": "CertificationCompletedPayload schema from Adobe Learning Manager Webhooks",
  "allOf": [
    {
      "type": "object",
      "description": "Base schema for all webhook event payloads",
      "required": [
        "eventType",
        "eventId",
        "accountId",
        "timestamp"
      ],
      "properties": {
        "eventType": {
          "type": "string",
          "description": "The type of event that triggered this webhook"
        },
        "eventId": {
          "type": "uuid",
          "description": "Unique identifier for this event instance"
        },
        "accountId": {
          "type": "string",
          "description": "The Learning Manager account ID"
        },
        "timestamp": {
          "type": "datetime",
          "description": "ISO 8601 timestamp when the event occurred"
        },
        "source": {
          "type": "string",
          "description": "The system component that generated the event",
          "enum": [
            "learner",
            "admin",
            "manager",
            "system",
            "api"
          ]
        }
      }
    },
    {
      "type": "object",
      "properties": {
        "eventType": {
          "const": "CERTIFICATION_COMPLETED"
        },
        "learner": {
          "type": "object",
          "description": "Reference to a learner involved in an event",
          "properties": {
            "userId": {
              "type": "string",
              "description": "Unique user identifier"
            },
            "name": {
              "type": "string",
              "description": "Learner's full name"
            },
            "email": {
              "type": "string",
              "format": "email",
              "description": "Learner's email address"
            }
          }
        },
        "certification": {
          "type": "object",
          "properties": {
            "certificationId": {
              "type": "string",
              "description": "Certification identifier"
            },
            "name": {
              "type": "string",
              "description": "Certification name"
            },
            "instanceId": {
              "type": "string",
              "description": "Certification instance identifier"
            }
          }
        },
        "completedOn": {
          "type": "datetime",
          "description": "Completion timestamp"
        },
        "validUntil": {
          "type": "datetime",
          "description": "Certification validity expiration date"
        },
        "recertificationDeadline": {
          "type": "datetime",
          "description": "Deadline for recertification"
        }
      }
    }
  ]
}